FROM ubuntu:latest

RUN apt update && apt install -y \
  less \
  vim \
  curl \
  ca-certificates \
  openssh-client \
  iproute2

# Add custom user
ENV UNAME=codex-client-user
RUN useradd -m $UNAME

# SSH setup
RUN mkdir -p /home/$UNAME/.ssh && \
    chown -R $UNAME:$UNAME /home/$UNAME/.ssh && \
    chmod 700 /home/$UNAME/.ssh

# Download and install Codex as non-root user
USER $UNAME
WORKDIR /home/$UNAME
RUN curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh
ENV PATH="/home/$UNAME/.local/bin:${PATH}"
ENV CODEX_HOME=/home/$UNAME/.codex

# Copy the needed Codex files over to the image
COPY --chown=$UNAME:$UNAME Codex/Client/config.toml $CODEX_HOME/
COPY --chown=$UNAME:$UNAME Codex/Qwen3-Coder-Next.json $CODEX_HOME/model-catalogs/
